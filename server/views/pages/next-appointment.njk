{% extends "../partials/layout.njk" %}

{% set pageTitle = applicationName + " - Home" %}
{% set mainClasses = "app-container govuk-body" %}

{% block content %}

    {% from "moj/components/side-navigation/macro.njk" import mojSideNavigation %}
    {% from "govuk/components/button/macro.njk" import govukButton %}
    {% from "govuk/components/radios/macro.njk" import govukRadios %}
    {% from "govuk/components/input/macro.njk" import govukInput %}
    {% from "govuk/components/table/macro.njk" import govukTable %}

    <form method="post">

        {% set errorList =[
            { text: errorMessages.contactByPhone.text, href: "#contact-by-phone" } if errorMessages.contactByPhone else None,
            { text: errorMessages.genericErrorMessage.text, href: "#" } if errorMessages.genericErrorMessage else None,
            { text: errorMessages.alternateAppoinmentNoAlternateAddress.text, href: "#" } if errorMessages.alternateAppoinmentNoAlternateAddress else None,
            { text: errorMessages.nextAppointmentNoAddressSelection.text, href: "#" } if errorMessages.nextAppointmentNoAddressSelection else None
        ] | reject("undefined") %}

        {% if errorMessages | length > 0 %}
            {% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

            {{ govukErrorSummary({ titleText: "There is a problem", errorList: errorList }) }}
        {% endif %}

        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        <div class="govuk-grid-row">
            <div class="govuk-grid-column-one-third">

                {% include "pages/side-nav.njk" %}

            </div>

            <div class="govuk-grid-column-two-thirds">
              {% if not showEmbeddedError %}
              {% include "partials/review-required.njk" %}

                <h1 class="govuk-heading-l">Breach Notice - Next Appointment</h1>

                <h2 class="govuk-heading-m">Responsible Officer</h2>
                <p id="responsible-officer">{{ responsibleOfficerDisplayValue }}</p>

                <h2 class="govuk-heading-m">Contact Number</h2>
                <p id="contact-number">
                  {% if nextAppointmentDetails.responsibleOfficer.telephoneNumber %}
                    {{ nextAppointmentDetails.responsibleOfficer.telephoneNumber }}
                  {% else %}
                    No Contact Number found for this Responsible Officer
                  {% endif %}
                </p>

                {% set phoneHtml %}
                    {{ govukInput({
                        id: "contact-by-phone",
                        name: "contactByPhone",
                        type: "tel",
                        autocomplete: "tel",
                        value: breachNotice.optionalNumber,
                        classes: "govuk-!-width-one-third",
                        label: {
                            text: "Phone number"
                        },
                        errorMessage: {
                            text: errorMessages.contactByPhone.text
                        } if errorMessages.contactByPhone.text
                    }) }}
                {% endset -%}

                {{ govukRadios({
                    name: "useContactNumber",
                    value: useContactNumber,
                    fieldset: {
                        legend: {
                            text: "Would you like to use the contact number above for this breach notice?",
                            isPageHeading: false,
                            classes: "govuk-fieldset__legend--m"
                        }
                    },
                    hint: {
                        text: "Select one option"
                    },
                    items: [
                        {
                            value: "Yes",
                            text: "Yes"
                        },
                        {
                            value: "No",
                            text: "No, I would like to use a different contact number ",
                            conditional: {
                            html: phoneHtml
                        }
                        }
                    ]
                }) }}

              {% set appointmentSelection %}
                {% if appointmentRadioButtons and appointmentRadioButtons | length > 0 %}
                  <div class="govuk-form-group">
                    <fieldset class="govuk-fieldset"
                              aria-describedby="appt-hint">
                      <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
                        <h1 class="govuk-fieldset__heading">
                          Please Select an Appointment
                        </h1>
                      </legend>

                      <div id=appt-hint" class="govuk-hint">
                        Select one option
                      </div>

                      <div class="govuk-radios"
                           data-module="govuk-radios">



                        {% for appointmentRadioButton in appointmentRadioButtons %}
                          <div class="govuk-radios__item">
                            <input class="govuk-radios__input"
                                   id="appointment_{{ appointmentRadioButton.value }}"
                                   name="appointmentSelection"
                              {{ "checked" if appointmentRadioButton.checked else "" }}
                                   type="radio"
                                   value="{{ appointmentRadioButton.value }}"
                                   data-aria-controls="conditional-address-{{ appointmentRadioButton.value }}">
                            <label class="govuk-label govuk-radios__label" for="appointment_{{ appointmentRadioButton.value }}">
                              {{ appointmentRadioButton.text }}
                            </label>
                          </div>
                          <div class="govuk-radios__conditional govuk-radios__conditional--hidden"
                               id="conditional-address-{{ appointmentRadioButton.value }}">



                            <div class="govuk-form-group">
                              <fieldset class="govuk-fieldset"
                                        aria-describedby="use-address-hint">
                                <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
                                  <h1 class="govuk-fieldset__heading">
                                    Do you want to use the address above?
                                  </h1>
                                </legend>
                                <div id="use-address-hint" class="govuk-hint">
                                  Select one option
                                </div>
                                <div class="govuk-radios" data-module="govuk-radios">
                                  <div class="govuk-radios__item">
                                    <input class="govuk-radios__input"
                                           id="alt-address-radio-yes_{{ appointmentRadioButton.value }}"
                                           name="altAddressRadio_{{ appointmentRadioButton.value }}"
                                      {{ "checked" if (appointmentRadioButton.checked and useAboveAddress !== null and useAboveAddress === true) else "" }}
                                           type="radio"
                                           value="Yes">
                                    <label class="govuk-label govuk-radios__label" for="alt-address-radio_yes_{{ appointmentRadioButton.value }}">
                                      Yes
                                    </label>
                                  </div>
                                  <div class="govuk-radios__item">
                                    <input class="govuk-radios__input"
                                           id="alt-address-radio-no_{{ appointmentRadioButton.value }}"
                                           name="altAddressRadio_{{ appointmentRadioButton.value }}"
                                      {{ "checked" if (appointmentRadioButton.checked and useAboveAddress !== null and useAboveAddress === false) else "" }}
                                           type="radio"
                                           value="No"
                                           data-aria-controls="conditional-alt-address-section_{{ appointmentRadioButton.value }}">
                                    <label class="govuk-label govuk-radios__label" for="alt-address-radio_no_{{ appointmentRadioButton.value }}">
                                      No, I would like to use a different address
                                    </label>
                                  </div>
                                  <div class="govuk-radios__conditional govuk-radios__conditional--hidden"
                                       id="conditional-alt-address-section_{{ appointmentRadioButton.value }}">

                                    {% if (showAddAddress and appointmentRadioButton.checked) or not appointmentRadioButton.checked %}
                                      <div class="govuk-form-group">
                                        <label class="govuk-heading-m">
                                          Please use the button below to add a different address
                                        </label>

                                        {{ govukButton({
                                          text: "Save Progress and Add Address" ,
                                          preventDoubleClick: "true",
                                          type: "submit",
                                          name: "action",
                                          value: "alternateAddressForAppointment_"+appointmentRadioButton.value,
                                          classes: "govuk-button--primary",
                                          attributes: {
                                            id: "add-alternate-address-button"
                                          }
                                        }) }}
                                      </div>
                                    {% endif %}

                                    {% if showUpdateAddress and appointmentRadioButton.checked %}
                                      <div class="govuk-form-group">
                                        <p id="postal-address">
                                          {% if breachNotice.alternateNextAppointmentLocation.buildingName %} {{ breachNotice.alternateNextAppointmentLocation.buildingName }}
                                            <br/>{% endif %}
                                          {% if breachNotice.alternateNextAppointmentLocation.buildingName or breachNotice.alternateNextAppointmentLocation.streetName %} {{ breachNotice.alternateNextAppointmentLocation.buildingNumber }} {{ breachNotice.alternateNextAppointmentLocation.streetName }}
                                            <br/>{% endif %}
                                          {% if breachNotice.alternateNextAppointmentLocation.district %} {{ breachNotice.alternateNextAppointmentLocation.district }}<br/>{% endif %}
                                          {% if breachNotice.alternateNextAppointmentLocation.townCity %} {{ breachNotice.alternateNextAppointmentLocation.townCity }}<br/>{% endif %}
                                          {% if breachNotice.alternateNextAppointmentLocation.county %} {{ breachNotice.alternateNextAppointmentLocation.county }}<br/>{% endif %}
                                          {% if breachNotice.alternateNextAppointmentLocation.postcode %} {{ breachNotice.alternateNextAppointmentLocation.postcode }}<br/>{% endif %}
                                        </p>

                                        <label class="govuk-heading-m">
                                          Please use the button below to update the address
                                        </label>

                                        {{ govukButton({
                                          text: "Save Progress and Update Address" ,
                                          preventDoubleClick: "true",
                                          type: "submit",
                                          name: "action",
                                          value: "alternateAddressForAppointment_"+appointmentRadioButton.value,
                                          classes: "govuk-button--primary",
                                          attributes: {
                                            id: "update-alternate-address-button"
                                          }
                                        }) }}
                                      </div>

                                    {% endif %}
                                  </div>
                                </div>
                              </fieldset>
                            </div>
                          </div>
                        {% endfor %}
                      </div>
                    </fieldset>
                  </div>
                  {% else %}
                    <p id="no-appointment-error" class="govuk-error-message">
                      <span>No future appointments are available to select at this time. Please add an appointment in NDelius and refresh this screen if one is required.</span>
                    </p>
                {% endif %}







              {% endset -%}

              {{ govukRadios({
                name: "selectNextAppointment",
                value: selectNextAppointment,
                fieldset: {
                  legend: {
                    text: "Do you want to select a Next Appointment?",
                    isPageHeading: false,
                    classes: "govuk-fieldset__legend--m"
                  }
                },
                hint: {
                  text: "Select one option"
                },
                items: [
                  {
                    value: "No",
                    text: "No"
                  },
                  {
                    value: "Yes",
                    text: "Yes",
                    conditional: {
                    html: appointmentSelection
                  }
                  }
                ]
              }) }}

                <div class="moj-button-group">
                  {{ govukButton({
                    text: "Continue",
                    preventDoubleClick: "true",
                    type: "submit",
                    attributes: {
                      id: "continue-button"
                    }
                  }) }}
                  {{ govukButton({
                    text: "Refresh from Delius",
                    preventDoubleClick: "true",
                    type: "submit",
                    name: "action",
                    value: "refreshData",
                    classes: "govuk-button--secondary",
                    attributes: {
                      id: "refresh-button"
                    }
                  }) }}
                  {{ govukButton({
                    text: "Save Progress and Close",
                    type: "submit",
                    name: "action",
                    value: "saveProgressAndClose",
                    classes: "govuk-button--secondary",
                    attributes: {
                      id: "close-button"
                    }
                  }) }}
                </div>
              {% endif %}
            </div>
        </div>
    </form>
{% endblock %}
